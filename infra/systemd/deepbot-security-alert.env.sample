# deepbot security environment sample for systemd
# Place these keys in /opt/deepbot/.env.deepbot

SECURITY_ENABLED=true
SECURITY_ALERT_BIND_HOST=127.0.0.1
SECURITY_ALERT_BIND_PORT=8088
SECURITY_RULES_PATH=/opt/deepbot/config/security/detection-rules.yaml
SECURITY_ALLOWLIST=
SECURITY_STATE_DIR=/opt/deepbot/workspace/security
SECURITY_ALERT_CHANNEL_ID=replace-with-discord-channel-id

SECURITY_PORT_MONITOR_ENABLED=true
SECURITY_PORT_MONITOR_INTERVAL_SECONDS=60
SECURITY_PORT_MONITOR_PROTOCOLS=tcp
SECURITY_PORT_MONITOR_EXCLUDE_PORTS=22

SECURITY_RESOURCE_MONITOR_ENABLED=true
SECURITY_RESOURCE_MONITOR_INTERVAL_SECONDS=60
SECURITY_CPU_LOAD_PERCENT_THRESHOLD=85
SECURITY_MEMORY_PERCENT_THRESHOLD=90
SECURITY_DISK_PERCENT_THRESHOLD=90
